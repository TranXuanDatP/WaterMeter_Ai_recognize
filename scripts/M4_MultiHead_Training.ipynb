   "source": [
    "## ⚖️ Layer 3: Weighted Loss - MultiHead (CTC + SAR)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class MultiHeadLoss(nn.Module):\n",
    "    \"\"\"\n",
    "    MultiHead Loss: CTC + SAR với digit weights\n",
    "    \n",
    "    ⚠️ CRITICAL:\n",
    "    - CTC blank index = 10\n",
    "    - SOS token = 11\n",
    "    \"\"\"\n",
    "    def __init__(self, digit_weights=None, ctc_blank=10, sos_token=11):\n",
    "        super().__init__()\n",
    "        self.ctc_blank = ctc_blank\n",
    "        self.sos_token = sos_token\n",
    "        \n",
    "        # Digit weights for SAR loss\n",
    "        if digit_weights is None:\n",
    "            self.digit_weights = torch.tensor([\n",
    "                0.5,  # 0: GIẢM - AI bớt đoán mò\n",
    "                3.5,  # 1: 370 errors - cao nhất\n",
    "                1.5,  # 2\n",
    "                1.5,  # 3\n",
    "                2.0,  # 4\n",
    "                2.0,  # 5\n",
    "                4.0,  # 6: TARGET! 8x vs 0\n",
    "                2.0,  # 7\n",
    "                3.0,  # 8\n",
    "                2.5,  # 9\n",
    "                1.0,  # 10: Blank (CTC only)\n",
    "                1.0,  # 11: SOS (SAR only)\n",
    "            ])\n",
    "        else:\n",
    "            self.digit_weights = torch.tensor(digit_weights)\n",
    "        \n",
    "        self.ctc_loss = nn.CTCLoss(blank=ctc_blank, reduction='none')\n",
    "        self.sar_criterion = nn.CrossEntropyLoss(reduction='none')\n",
    "        \n",
    "        # Loss weights\n",
    "        self.ctc_weight = 0.3  # CTC đóng góp 30%\n",
    "        self.sar_weight = 0.7  # SAR đóng góp 70% (quan trọng hơn)\n",
    "    \n",
    "    def forward(self, ctc_logits, sar_logits, targets, input_lengths, target_lengths):\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            ctc_logits: (T, N, C)\n",
    "            sar_logits: (N, max_len, C)\n",
n",
    "            targets: Concatenated target labels\n",
    "            input_lengths: (N,) - length of each CTC sequence\n",
    "            target_lengths: (N,) - length of each target\n",
    "        \"\"\"\n",
    "        batch_size = ctc_logits.size(1)\n",
    "        device = ctc_logits.device\n",
    "        \n",
    "        # ========== CTC Loss ==========\n",
    "        log_probs = ctc_logits.log_softmax(2)\n",
    "        \n",
    "        ctc_losses = []\n",
    "        for i in range(batch_size):\n",
    "            target_i = targets[\n",
    "                sum(target_lengths[:i]):sum(target_lengths[:i+1])\n",
    "            ]\n",
    "            loss_i = self.ctc_loss(\n",
    "                log_probs[:, i:i+1, :],\n",
    "                target_i.unsqueeze(0),\n",
    "                input_lengths[i:i+1],\n",
    "                target_lengths[i:i+1]\n",
    "            )\n",
    "            ctc_losses.append(loss_i)\n",
    "        \n",
    "        ctc_loss = torch.stack(ctc_losses).mean()\n",
    "        \n",
    "        # ========== SAR Loss ==========\n",
    "        # Reshape targets for SAR: (batch, max_len)\n",
    "        max_len = sar_logits.size(1)\n",
    "        \n",
    "        sar_targets_list = []\n",
    "        for i in range(batch_size):\n",
    "            target_i = targets[\n",
    "                sum(target_lengths[:i]):sum(target_lengths[:i+1])\n",
    "            ]\n",
    "            # Pad to max_len\n",
    "            if len(target_i) < max_len:\n",
    "                target_i = F.pad(target_i, (0, max_len - len(target_i)), value=10)  # Pad with blank\n",
    "            sar_targets_list.append(target_i)\n",
    "        \n",
    "        sar_targets = torch.stack(sar_targets_list)  # (batch, max_len)\n",
    "        \n",
    "        # Calculate SAR loss with digit weights\n",
    "        sar_losses = []\n",
    "        for i in range(batch_size):\n",
    "            for t in range(max_len):\n",
    "                target_t = sar_targets[i, t]\n",
    "                if target_t < 10:  # Only weight digits, not blank/SOS\n",
    "                    weight = self.digit_weights[target_t].to(device)\n",
    "                else:\n",
    "                    weight = 1.0\n",
    "                \n",
    "                loss_t = self.sar_criterion(\n",
    "                    sar_logits[i:i+1, t, :],\n",
    "                    sar_targets[i:i+1, t]\n",
    "                ) * weight\n",
    "                sar_losses.append(loss_t)\n",
    "        \n",
    "        sar_loss = torch.stack(sar_losses).mean() if sar_losses else torch.tensor(0.0).to(device)\n",
    "        \n",
    "        # ========== Combined Loss ==========\n",
    "        total_loss = self.ctc_weight * ctc_loss + self.sar_weight * sar_loss\n",
    "        \n",
    "        return {\n",
    "            'total': total_loss,\n",
    "            'ctc': ctc_loss,\n",
    "            'sar': sar_loss\n",
    "        }\n",
    "\n",
    "# Initialize loss\n",
    "criterion = MultiHeadLoss()\n",
    "print(\"✅ MultiHead Loss initialized!\")\n",
    "print(f\"   CTC weight: {criterion.ctc_weight}\")\n",
    "print(f\"   SAR weight: {criterion.sar_weight}\")\n",
    "print(f\"   CTC blank: {criterion.ctc_blank}\")\n",
    "print(f\"   SOS token: {criterion.sos_token}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔍 Layer 2: Sharpening Pre-processing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class SharpenTransform:\n",
    "    \"\"\"\n",
    "    Layer 2: Sharpening Pre-processing - \"Magnifying Glass\" for blurry 6→0\n",
    "    \"\"\"\n",
    "    def __init__(self, sharpen_strength=1.5, clahe_clip=2.0):\n",
    "        self.sharpen_strength = sharpen_strength\n",
    "        self.clahe_clip = clahe_clip\n",
    "\n",
    "    def __call__(self, image: np.ndarray) -> np.ndarray:\n",
    "        # Convert to grayscale if needed\n",
    "        if len(image.shape) == 3:\n",
    "            gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)\n",
    "        else:\n",
    "            gray = image.copy()\n",
    "\n",
    "        # Unsharp Masking\n",
    "        blurred = cv2.GaussianBlur(gray, (0, 0), 3)\n",
    "        sharpened = cv2.addWeighted(\n",
    "            gray, 1 + self.sharpen_strength,\n",
    "            blurred, -self.sharpen_strength,\n",
    "            0\n",
    "        )\n",
    "\n",
    "        # CLAHE\n",
    "        clahe = cv2.createCLAHE(clipLimit=self.clahe_clip, tileGridSize=(4, 4))\n",
    "        enhanced = clahe.apply(sharpened)\n",
    "\n",
    "        return enhanced\n",
    "\n",
    "sharpen_transform = SharpenTransform(sharpen_strength=1.5, clahe_clip=2.0)\n",
    "print(\"✅ Sharpening transform initialized!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📊 Layer 1: Dataset with WeightedRandomSampler"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class MeterDataset(Dataset):\n",
    "    \"\"\"\n",
    "    Dataset with digit-based sampling strategy\n",
    "    \n",
    "    ⚠️ CRITICAL FIX:\n",
    "    - Resize to (256, 48) - Đủ width cho CTC\n",
    "    \"\"\"\n",
    "    def __init__(self, images_dir, labels_file, sharpen=None):\n",
    "        self.images_dir = Path(images_dir)\n",
    "        self.sharpen = sharpen\n",
    "\n",
    "        # Load labels\n",
    "        self.labels_df = pd.read_csv(labels_file)\n",
    "        \n",
    "        # Calculate digit frequencies\n",
    "        digit_counts = Counter()\n",
    "        for _, row in self.labels_df.iterrows():\n",
    "            value = str(row['value'])\n",
    "            for digit in value:\n",
    "                if digit.isdigit():\n",
    "                    digit_counts[int(digit)] += 1\n",
    "\n",
    "        print(\"Digit distribution in dataset:\")\n",
    "        total_digits = sum(digit_counts.values())\n",
    "        for digit in sorted(digit_counts.keys()):\n",
    "            count = digit_counts[digit]\n",
    "            print(f\"  Digit {digit}: {count:5d} occurrences ({count/total_digits*100:5.2f}%)\")\n",
    "\n",
    "        # Calculate sample weights\n",
    "        self.sample_weights = []\n",
    "        for _, row in self.labels_df.iterrows():\n",
    "            value = str(row['value'])\n",
    "            \n",
    "            # Find rarest digit\n",
    "            min_freq = float('inf')\n",
    "            for digit in value:\n",
    "                if digit.isdigit():\n",
    "                    freq = digit_counts[int(digit)]\n",
    "                    min_freq = min(min_freq, freq)\n",
    "            \n",
    "            # Inverse frequency\n",
    "            weight = 1.0 / (min_freq + 1e-6)\n",
    "            self.sample_weights.append(weight)\n",
    "        \n",
    "        # Normalize weights\n",
    "        total_weight = sum(self.sample_weights)\n",
    "        self.sample_weights = [w / total_weight for w in self.sample_weights]\n",
    "        \n",
    "        print(f\"\\nSample weight range: {min(self.sample_weights):.6f} - {max(self.sample_weights):.6f}\")\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.labels_df)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        row = self.labels_df.iloc[idx]\n",
    "        img_path = self.images_dir / row['photo_name']\n",
    "\n",
    "        # Load image\n",
    "        image = cv2.imread(str(img_path))\n",
    "        if image is None:\n",
    "            raise ValueError(f\"Cannot load image: {img_path}\")\n",
    "\n",
    "        # Apply sharpening\n",
    "        if self.sharpen is not None:\n",
    "            image = self.sharpen(image)\n",
    "        else:\n",
    "            if len(image.shape) == 3:\n",
    "                image = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)\n",
    "\n",
    "        # ⚠️ FIX: Resize to (256, 48) - Tăng width để đủ sequence length\n",
    "        image = cv2.resize(image, (256, 48))\n",
    "\n",
    "        # Normalize\n",
    "        image = image.astype(np.float32) / 255.0\n",
    "        image = (image - 0.5) / 0.5\n",
    "\n",
    "        # Get label\n",
    "        label = str(row['value'])\n",
    "        label_indices = [int(d) for d in label if d.isdigit()]\n",
    "\n",
    "        return {\n",
    "            'image': torch.from_numpy(image).unsqueeze(0).float(),\n",
    "            'label': torch.tensor(label_indices, dtype=torch.long),\n",
    "            'label_length': len(label_indices),\n",
    "            'text': label\n",
    "        }\n",
    "\n",
    "print(\"✅ MeterDataset defined!\")\n",
    "print(\"   ⚠️  Image size: (256, 48)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔄 Helper Functions - Tự động tính input_lengths"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def collate_fn(batch):\n",
    "    \"\"\"\n",
    "    Custom collate function với AUTO input_lengths\n",
    "    \n",
    "    ⚠️ CRITICAL FIX:\n",
    "    - Input width: 256\n",
    "    - Width reduction: 8x (do stride=(2,1))\n",
    "    - Output width: 256/8 = 32 time steps\n",
    "    \"\"\"\n",
    "    images = torch.stack([item['image'] for item in batch])\n",
    "    labels = torch.cat([item['label'] for item in batch])\n",
    "    label_lengths = torch.tensor([item['label_length'] for item in batch])\n",
    "    \n",
    "    # ⚠️ FIX: Tính đúng output width\n",
    "    # Input: 256, Reduction: 8x → Output: 32\n",
    "    input_lengths = torch.tensor([32] * len(batch), dtype=torch.long)\n",
    "\n",
    "    # SAR targets: (batch, max_len)\n",
    "    max_len = max(item['label_length'] for item in batch)\n",
    "    sar_targets = []\n",
    "    for item in batch:\n",
    "        label = item['label']\n",
    "        if len(label) < max_len:\n",
    "            label = F.pad(label, (0, max_len - len(label)), value=10)  # Pad with blank\n",
    "        sar_targets.append(label)\n",
    "    sar_targets = torch.stack(sar_targets)\n",
    "\n",
    "    return {\n",
    "        'images': images,\n",
    "        'labels': labels,\n",
    "        'input_lengths': input_lengths,\n",
    "        'label_lengths': label_lengths,\n",
    "        'sar_targets': sar_targets,\n",
    "        'texts': [item['text'] for item in batch]\n",
    "    }\n",
    "\n",
    "print(\"✅ Collate function defined!\")\n",
    "print(\"   ⚠️  input_lengths = 32 (calculated from 256/8)\")"
   ]
  },
