   "source": [
    "## 🔧 Define MobileNetV1 Encoder with FIXED Stride\n",
    "\n",
    "⚠️ **CRITICAL**: Stride=(2,1) để giữ width, chỉ giảm height"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class DepthwiseSeparableConv(nn.Module):\n",
    "    \"\"\"Depthwise Separable Convolution\"\"\"\n",
    "    def __init__(self, in_channels, out_channels, stride=1):\n",
    "        super().__init__()\n",
    "        self.depthwise = nn.Conv2d(\n",
    "            in_channels, in_channels, kernel_size=3, \n",
    "            stride=stride, padding=1, groups=in_channels\n",
    "        )\n",
    "        self.pointwise = nn.Conv2d(\n",
    "            in_channels, out_channels, kernel_size=1, stride=1\n",
    "        )\n",
    "        self.bn1 = nn.BatchNorm2d(in_channels)\n",
    "        self.bn2 = nn.BatchNorm2d(out_channels)\n",
    "        self.relu = nn.ReLU(inplace=True)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        x = self.depthwise(x)\n",
    "        x = self.bn1(x)\n",
    "        x = self.relu(x)\n",
    "        x = self.pointwise(x)\n",
    "        x = self.bn2(x)\n",
    "        x = self.relu(x)\n",
    "        return x\n",
    "\n",
    "\n",
    "class MobileNetV1Encoder(nn.Module):\n",
    "    \"\"\"\n",
    "    MobileNetV1 Encoder với FIXED stride để giữ width\n",
    "    \n",
    "    ⚠️ CRITICAL FIX:\n",
    "    - stride=(2,1): Chỉ giảm HEIGHT, giữ WIDTH\n",
    "    - Mục tiêu: Width reduction = 8x (thay vì 32x)\n",
    "    \"\"\"\n",
    "    def __init__(self, num_channels=1):\n",
    "        super().__init__()\n",
    "        \n",
    "        # Initial conv\n",
    "        self.conv1 = nn.Conv2d(num_channels, 32, kernel_size=3, stride=1, padding=1)\n",
    "        self.bn1 = nn.BatchNorm2d(32)\n",
    "        self.relu = nn.ReLU(inplace=True)\n",
    "        \n",
    "        # ⚠️ FIXED: Dùng stride=(2,1) để giữ width\n",
    "        self.dw_conv_layers = nn.ModuleList([\n",
    "            # Layer 1: 32 -> 64, stride=1 (giữ nguyên)\n",
    "            DepthwiseSeparableConv(32, 64, stride=1),\n",
    "            \n",
    "            # Layer 2: 64 -> 128, stride=(2,1) ⚠️ CHỈ GIẢM H, GIỮ W\n",
    "            DepthwiseSeparableConv(64, 128, stride=(2, 1)),\n",
    "            \n",
    "            # Layer 3: 128 -> 128, stride=1\n",
    "            DepthwiseSeparableConv(128, 128, stride=1),\n",
    "            \n",
    "            # Layer 4: 128 -> 256, stride=(2,1) ⚠️ CHỈ GIẢM H, GIỮ W\n",
    "            DepthwiseSeparableConv(128, 256, stride=(2, 1)),\n",
    "            \n",
    "            # Layer 5: 256 -> 256, stride=1\n",
    "            DepthwiseSeparableConv(256, 256, stride=1),\n",
    "            \n",
    "            # Layer 6: 256 -> 512, stride=(2,1) ⚠️ CHỈ GIẢM H, GIỮ W\n",
    "            DepthwiseSeparableConv(256, 512, stride=(2, 1)),\n",
    "            \n",
    "        ])\n",
    "        \n",
    "    def forward(self, x):\n",
    "        # Initial conv\n",
    "        x = self.conv1(x)\n",
    "        x = self.bn1(x)\n",
    "        x = self.relu(x)\n",
    "        \n",
    "        # Store intermediate features for attention\n",
    "        features = []\n",
    "        \n",
    "        # Depthwise separable convs\n",
    "        for dw_conv in self.dw_conv_layers:\n",
    "            x = dw_conv(x)\n",
    "            features.append(x)\n",
    "        \n",
    "        return x, features\n",
    "\n",
    "print(\"✅ MobileNetV1 Encoder defined with FIXED stride=(2,1)!\")\n",
    "print(\"   ⚠️  Width reduction: 8x (not 32x)\")\n",
    "print(\"   ⚠️  Height reduction: 8x\")"
   ]
  },
