   "source": [
    "## 🎯 MultiHead OCR Model - CTC + SAR"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class AttentionLayer(nn.Module):\n",
    "    \"\"\"Bahdanau Attention cho SAR Head\"\"\"\n",
    "    def __init__(self, hidden_size):\n",
    "        super().__init__()\n",
    "        self.attention = nn.Linear(hidden_size * 2, hidden_size)\n",
    "        self.v = nn.Linear(hidden_size, 1, bias=False)\n",
    "    \n",
    "    def forward(self, hidden, encoder_outputs):\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            hidden: (batch, hidden_size*2) - Decoder hidden state\n",
    "            encoder_outputs: (batch, seq_len, hidden_size*2) - Encoder outputs\n",
    "        Returns:\n",
    "            context: (batch, hidden_size*2)\n",
    "            attention_weights: (batch, seq_len)\n",
    "        \"\"\"\n",
    "        # Calculate attention scores\n",
    "        energy = torch.tanh(self.attention(encoder_outputs))  # (batch, seq_len, hidden_size)\n",
    "        energy = self.v(energy).squeeze(-1)  # (batch, seq_len)\n",
    "        \n",
    "        # Calculate attention weights\n",
    "        attention_weights = F.softmax(energy, dim=1)  # (batch, seq_len)\n",
    "        \n",
    "        # Calculate context vector\n",
    "        context = torch.bmm(\n",
    "            attention_weights.unsqueeze(1), \n",
    "            encoder_outputs\n",
    "        ).squeeze(1)  # (batch, hidden_size*2)\n",
    "        \n",
    "        return context, attention_weights\n",
    "\n",
    "\n",
    "class SARDecoder(nn.Module):\n",
    "    \"\"\"\n",
    "    Show, Attend and Read Decoder\n",
    "    \n",
    "    ⚠️ CRITICAL FIX:\n",
    "    - SOS token index = 11 (không conflict với digit 0)\n",
    "    - Num classes = 12 (0-9 digits + blank + SOS)\n",
    "    \"\"\"\n",
    "    def __init__(self, num_classes=12, hidden_size=256, sos_token=11):\n",
    "        super().__init__()\n",
    "        self.num_classes = num_classes\n",
    "        self.sos_token = sos_token\n",
    "        self.hidden_size = hidden_size\n",
    "        \n",
    "        # Embedding for input tokens\n",
    "        self.embedding = nn.Embedding(num_classes, hidden_size)\n",
    "        \n",
    "        # Attention\n",
    "        self.attention = AttentionLayer(hidden_size)\n",
    "        \n",
    "        # LSTM\n",
    "        self.lstm = nn.LSTM(\n",
    "            input_size=hidden_size * 3,  # embedding + context + prev_hidden\n",
    "            hidden_size=hidden_size,\n",
    "            num_layers=1,\n",
    "            bidirectional=False,\n",
    "            batch_first=True\n",
    "        )\n",
    "        \n",
    "        # Output projection\n",
    "        self.fc_out = nn.Linear(hidden_size * 2, num_classes)  # hidden + context\n",
    "        \n",
    "        # Dropout\n",
    "        self.dropout = nn.Dropout(0.3)\n",
    "    \n",
    "    def forward(self, encoder_outputs, targets=None, max_length=4):\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            encoder_outputs: (batch, seq_len, hidden_size*2)\n",
    "            targets: (batch, max_len) - for training\n",
    "            max_length: max sequence length\n",
    "        Returns:\n",
    "            outputs: (batch, max_length, num_classes)\n",
    "        \"\"\"\n",
    "        batch_size = encoder_outputs.size(0)\n",
    "        device = encoder_outputs.device\n",
    "        \n",
    "        # Initialize hidden state\n",
    "        h = torch.zeros(1, batch_size, self.hidden_size).to(device)\n",
    "        c = torch.zeros(1, batch_size, self.hidden_size).to(device)\n",
    "        \n",
    "        # Initialize with SOS token\n",
    "        # ⚠️ FIX: Use sos_token=11, NOT 0 (conflict with digit 0)\n",
    "        current_token = torch.full((batch_size,), self.sos_token, \n",
    "                                   dtype=torch.long, device=device)\n",
    "        \n",
    "        outputs = []\n",
    "        \n",
    "        for t in range(max_length):\n",
    "            # Embed current token\n",
    "            token_embed = self.embedding(current_token)  # (batch, hidden_size)\n",
    "            \n",
    "            # Get previous hidden state\n",
    "            prev_hidden = h.permute(1, 0, 2).squeeze(1)  # (batch, hidden_size)\n",
    "            \n",
    "            # Apply attention\n",
    "            context, attn_weights = self.attention(prev_hidden, encoder_outputs)\n",
    "            \n",
    "            # Concatenate embedding, context, and prev hidden\n",
    "            lstm_input = torch.cat([token_embed, context, prev_hidden], dim=1)\n",
    "            lstm_input = lstm_input.unsqueeze(1)  # (batch, 1, hidden_size*3)\n",
    "            \n",
    "            # LSTM step\n",
    "            _, (h, c) = self.lstm(lstm_input, (h, c))\n",
    "            \n",
    "            # Output projection\n",
    "            hidden = h.permute(1, 0, 2).squeeze(1)  # (batch, hidden_size)\n",
    "            output = torch.cat([hidden, context], dim=1)  # (batch, hidden_size*2)\n",
    "            output = self.fc_out(output)  # (batch, num_classes)\n",
    "            \n",
    "            outputs.append(output)\n",
    "            \n",
    "            # Teacher forcing during training\n",
    "            if targets is not None and t < max_length - 1:\n",
    "                current_token = targets[:, t]\n",
    "            else:\n",
    "                current_token = output.argmax(dim=1)\n",
    "        \n",
    "        outputs = torch.stack(outputs, dim=1)  # (batch, max_length, num_classes)\n",
    "        return outputs\n",
    "\n",
    "\n",
    "class MultiHeadOCR(nn.Module):\n",
    "    \"\"\"\n",
    "    MultiHead OCR Model: MobileNetV1 + CTC + SAR\n",
    "    \n",
    "    ⚠️ CRITICAL FIX:\n",
    "    - Input width: 256 (đủ sequence length)\n",
    "    - Stride=(2,1) để giữ width\n",
    "    - SOS token: index 11\n",
    "    - Num classes: 12 (0-9 + blank + SOS)\n",
    "    \"\"\"\n",
    "    def __init__(self, num_classes=12, num_channels=1, img_height=48, hidden_size=256):\n",
    "        super().__init__()\n",
    "        self.num_classes = num_classes\n",
    "        self.hidden_size = hidden_size\n",
    "        \n",
    "        # Encoder\n",
    "        self.encoder = MobileNetV1Encoder(num_channels)\n",
    "        \n",
    "        # BiLSTM for CTC\n",
    "        self.ctc_lstm = nn.LSTM(\n",
    "            input_size=512,  # Output from encoder\n",
    "            hidden_size=hidden_size,\n",
    "            num_layers=2,\n",
    "            bidirectional=True,\n",
    "            batch_first=True,\n",
    "            dropout=0.3\n",
    "        )\n",
    "        \n",
    "        # CTC Head\n",
    "        self.ctc_fc = nn.Linear(hidden_size * 2, num_classes)\n",
    "        \n",
    "        # SAR Decoder\n",
    "        self.sar_decoder = SARDecoder(num_classes, hidden_size, sos_token=11)\n",
    "        \n",
    "    def forward(self, x, targets=None, max_length=4):\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            x: (batch, channels, height, width)\n",
    "            targets: (batch, max_len) - for SAR training\n",
    "        Returns:\n",
    "            ctc_logits: (seq_len, batch, num_classes)\n",
    "            sar_logits: (batch, max_length, num_classes)\n",
    "        \"\"\"\n",
    "        # Encode\n",
    "        encoder_out, features = self.encoder(x)  # (batch, 512, H, W)\n",
    "        \n",
    "        # Reshape for LSTM: (batch, W, C*H)\n",
    "        b, c, h, w = encoder_out.size()\n",
    "        encoder_features = encoder_out.permute(0, 3, 1, 2).contiguous()\n",
    "        encoder_features = encoder_features.view(b, w, c * h)\n",
    "        \n",
    "        # CTC Path\n",
    "        ctc_out, _ = self.ctc_lstm(encoder_features)  # (batch, W, hidden*2)\n",
    "        ctc_logits = self.ctc_fc(ctc_out).permute(1, 0, 2)  # (W, batch, num_classes)\n",
    "        \n",
    "        # SAR Path\n",
    "        sar_logits = self.sar_decoder(encoder_features, targets, max_length)\n",
    "        \n",
    "        return ctc_logits, sar_logits\n",
    "\n",
    "print(\"✅ MultiHead OCR Model defined!\")\n",
    "print(\"   📌 Architecture: MobileNetV1 + CTC + SAR\")\n",
    "print(\"   ⚠️  Num classes: 12 (0-9 + blank + SOS)\")\n",
    "print(\"   ⚠️  SOS token: index 11 (not 0)\")"
   ]
  },
  {
