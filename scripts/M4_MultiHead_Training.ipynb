   "source": [
    "# Device\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"Device: {device}\")\n",
    "if torch.cuda.is_available():\n",
    "    print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
    "print()\n",
    "\n",
    "# ⚠️ TRAINING FROM SCRATCH\n",
    "print(\"=\"*70)\n",
    "print(\"⚠️  MULTIHEAD TRAINING FROM SCRATCH\")\n",
    "print(\"=\"*70)\n",
    "print()\n",
    "print(\"Architecture: MobileNetV1 + CTC + SAR\")\n",
    "print(\"Fixes applied:\")\n",
    "print(\"  ✅ Input width: 256 (not 192)\")\n",
    "print(\"  ✅ Stride: (2,1) to preserve width\")\n",
    "print(\"  ✅ SOS token: index 11 (not 0)\")\n",
    "print(\"  ✅ Num classes: 12 (0-9 + blank + SOS)\")\n",
    "print()\n",
    "\n",
    "# Create model\n",
    "model = MultiHeadOCR(num_classes=12, num_channels=1, img_height=48, hidden_size=256).to(device)\n",
    "\n",
    "# Count parameters\n",
    "total_params = sum(p.numel() for p in model.parameters())\n",
    "trainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "\n",
    "print(f\"✅ Model created!\")\n",
    "print(f\"   Total parameters: {total_params:,}\")\n",
    "print(f\"   Trainable parameters: {trainable_params:,}\")\n",
    "print(f\"   Model size: ~{total_params * 4 / 1024 / 1024:.2f} MB\")\n",
    "print()\n",
    "\n",
    "# 🔍 VERIFY ARCHITECTURE\n",
    "print(\"=\"*70)\n",
    "print(\"🔍 ARCHITECTURE VERIFICATION\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "# Test forward pass\n",
    "test_input = torch.randn(1, 1, 48, 256).to(device)\n",
    "with torch.no_grad():\n",
    "    ctc_out, sar_out = model(test_input)\n",
    "\n",
    "ctc_len = ctc_out.size(0)\n",
    "sar_len = sar_out.size(1)\n",
    "num_classes = ctc_out.size(2)\n",
    "\n",
    "print(f\"\\n📏 Input: (1, 1, 48, 256)\")\n",
    "print(f\"📐 Width reduction: 8x (stride=(2,1))\")\n",
    "print(f\"\\n✅ Output dimensions:\")\n",
    "print(f\"   CTC time steps: {ctc_len}\")\n",
    "print(f\"   SAR sequence: {sar_len}\")\n",
    "print(f\"   Num classes: {num_classes}\")\n",
    "\n",
    "print(f\"\\n🎯 CTC Alignment Check:\")\n",
    "print(f\"   Required for 4 digits: T ≥ 9\")\n",
    "print(f\"   Actual T: {ctc_len}\")\n",
    "if ctc_len >= 9:\n",
    "    print(f\"   ✅ PASS - Sufficient time steps!\")\n",
    "else:\n",
    "    print(f\"   ❌ FAIL - Need T ≥ 9, got {ctc_len}\")\n",
    "\n",
    "print(f\"\\n📋 Configuration:\")\n",
    "print(f\"   CTC blank index: 10\")\n",
    "print(f\"   SOS token index: 11\")\n",
    "print(f\"   Digit classes: 0-9\")\n",
    "print(f\"   input_lengths: 32\")\n",
    "print(\"=\"*70)\n",
    "print()\n",
    "\n",
    "# Load dataset\n",
    "print(\"[Loading Dataset with Layer 1: WeightedRandomSampler]\")\n",
    "dataset = MeterDataset(\n",
    "    images_dir=DATA_DIR,\n",
    "    labels_file=LABELS_FILE,\n",
    "    sharpen=sharpen_transform\n",
    ")\n",
    "print()\n",
    "\n",
    "# Split train/val\n",
    "train_size = int(0.8 * len(dataset))\n",
    "val_size = len(dataset) - train_size\n",
    "train_dataset, val_dataset = torch.utils.data.random_split(dataset, [train_size, val_size])\n",
    "\n",
    "# Layer 1: WeightedRandomSampler\n",
    "train_sampler = WeightedRandomSampler(\n",
    "    weights=[dataset.sample_weights[i] for i in train_dataset.indices],\n",
    "    num_samples=len(train_dataset),\n",
    "    replacement=True\n",
    ")\n",
    "\n",
    "train_loader = DataLoader(\n",
    "    train_dataset,\n",
    "    batch_size=32,\n",
    "    sampler=train_sampler,\n",
    "    collate_fn=collate_fn,\n",
    "    num_workers=2\n",
    ")\n",
    "\n",
    "val_loader = DataLoader(\n",
    "    val_dataset,\n",
    "    batch_size=32,\n",
    "    shuffle=False,\n",
    "    collate_fn=collate_fn,\n",
    "    num_workers=2\n",
    ")\n",
    "\n",
    "print(f\"✅ Train samples: {len(train_dataset)}\")\n",
    "print(f\"✅ Val samples: {len(val_dataset)}\")\n",
    "\n",
    "# Verify batch\n",
    "sample_batch = next(iter(train_loader))\n",
    "print(f\"\\n🔍 Batch verification:\")\n",
    "print(f\"   Images shape: {sample_batch['images'].shape}\")\n",
    "print(f\"   input_lengths: {sample_batch['input_lengths'][0].item()}\")\n",
    "print(f\"   Expected CTC T: {ctc_len}\")\n",
    "if sample_batch['input_lengths'][0].item() == ctc_len:\n",
    "    print(f\"   ✅ VERIFIED!\")\n",
    "else:\n",
    "    print(f\"   ❌ MISMATCH!\")"
   ]
