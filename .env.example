# Water Meter AI - Logging Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# GLOBAL LOGGING CONTROL
# =============================================================================

# Enable/disable ALL logging (true/false)
# When false, no logs will be output from any module
WATERMETER_ENABLE_LOG=true

# Set log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# - DEBUG: See all details including batch item processing (development)
# - INFO: See batch summaries and key milestones (production)
# - WARNING: Only warnings and errors
# - ERROR: Only errors
WATERMETER_LOG_LEVEL=INFO

# =============================================================================
# PER-MODULE LOGGING CONTROL
# =============================================================================

# Enable/disable logging for individual modules
# Overrides WATERMETER_ENABLE_LOG if set

# M1: Watermeter Detection
WATERMETER_LOG_M1=true

# M2: Orientation Alignment
WATERMETER_LOG_M2=true

# M3: Component Detection
WATERMETER_LOG_M3=true

# M4: CRNN Digit Recognition
WATERMETER_LOG_M4=true

# M5: Pointer Reading
WATERMETER_LOG_M5=true

# Bayesian Enhancement Layer
WATERMETER_LOG_BAYESIAN=true

# =============================================================================
# LOG LEVEL (Optional)
# =============================================================================

# Set log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# WATERMETER_LOG_LEVEL=INFO

# =============================================================================
# LOG LEVEL BEHAVIOR FOR BATCH PROCESSING
# =============================================================================

# Fix B: Batch processing uses different log levels
# - INFO level: Shows batch start, end, summary (success rate, avg time)
# - DEBUG level: Shows individual item details (avoid console spam)
#
# Example with WATERMETER_LOG_LEVEL=INFO:
#   [INFO] 🚦 detect_batch | Starting batch (size=1000)
#   [INFO] ✓ detect_batch | Batch complete: 1000/1000 (100.0%) | Time: 12345ms
#
# Example with WATERMETER_LOG_LEVEL=DEBUG:
#   [INFO] 🚦 detect_batch | Starting batch (size=1000)
#   [DEBUG] Processing item 1/1000
#   [DEBUG] Processing item 2/1000
#   ... (individual item details)
#   [INFO] ✓ detect_batch | Batch complete: 1000/1000 (100.0%) | Time: 12345ms

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================

# For production, you might want to:
# 1. Disable all logs (set WATERMETER_ENABLE_LOG=false)
# 2. Only log errors (set WATERMETER_LOG_LEVEL=ERROR)
# 3. Disable specific verbose modules

# Example production config:
# WATERMETER_ENABLE_LOG=true
# WATERMETER_LOG_LEVEL=WARNING
# WATERMETER_LOG_M1=false  # Disable verbose M1 logs
# WATERMETER_LOG_M2=false  # Disable verbose M2 logs
# WATERMETER_LOG_M3=false  # Disable verbose M3 logs
# WATERMETER_LOG_M4=true   # Keep M4 logs for monitoring CRNN
# WATERMETER_LOG_M5=true   # Keep M5 logs for monitoring pointers
# WATERMETER_LOG_BAYESIAN=true  # Keep Bayesian logs for debugging rolling digits
