# Docker-specific environment variables

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Logging
PYTHONUNBUFFERED=1
LOG_LEVEL=info

# Model Configuration
MODEL_PATH=/app/model
DEVICE=cpu

# Disable GPU in Docker (unless using nvidia-docker)
CUDA_VISIBLE_DEVICES=

# Application Settings
MAX_UPLOAD_SIZE=10485760
ALLOWED_ORIGINS=*
